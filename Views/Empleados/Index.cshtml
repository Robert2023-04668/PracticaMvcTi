@model PracticaMvcTi.PaginationDto<PracticaMvcTi.ViewModels.EmpleadoViewModel.EmpleadosDto>

@{
    ViewData["Title"] = "Gestión de Empleados";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-secondary fw-bold">Gestion de Empleados</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg"></i> Nuevo Empleado
        </a>
    </div>

    <form method="get" class="mb-3">

    <input type="text" name="search" 
           value="@ViewBag.CurrentSearch" 
           placeholder="Buscar..." />

    <input type="date" name="fechaInicio" 
           value="@ViewBag.FechaInicio" />

    <input type="date" name="fechaFin" 
           value="@ViewBag.FechaFin" />

    <button type="submit">Filtrar</button>

</form>

   

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Perfil</th>
                            <th>Nombre</th>
                            <th>Departamento</th>
                            <th>Puesto</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Data)
                        {
                            <tr>
                                <td class="ps-4">
                                    <img src="@item.ImagenPath"
                                         alt="Foto"
                                         class="rounded-circle shadow-sm border"
                                         style="width: 45px; height: 45px; object-fit: cover;"
                                         onerror="this.src='/img/default-avatar.png'" />
                                </td>
                                <td>
                                    <span class="fw-bold text-dark">@item.Nombre @item.Apellido</span>
                                </td>
                                <td>
                                    <span class="badge bg-info text-dark">@item.NombreDepartamento</span>
                                </td>
                                <td>@item.NombrePuesto</td>
                                <td>
                                    @{
                                        var statusClass = item.NombreEstado == "Activo" ? "bg-success" : "bg-secondary";
                                    }
                                    <span class="badge rounded-pill @statusClass">@item.NombreEstado</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.IdEmpleado" class="btn btn-outline-warning btn-sm" title="Editar">
                                            Editar
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.IdEmpleado" class="btn btn-outline-info btn-sm" title="Detalles">
                                            Detalles
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.IdEmpleado" class="btn btn-outline-danger btn-sm" title="Eliminar">
                                            Borrar
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>


    <partial name="_Pagination" model="Model" />
 
</div>