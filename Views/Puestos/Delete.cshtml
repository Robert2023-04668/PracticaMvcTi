@model PracticaMvcTi.ViewModels.PuestosViewModel.PuestosFormViewModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<form method="post">

    <p>Seguro de quere borrar este Puesto?</p>
    <div class="mb-3">
        <label asp-for="NombrePuesto" class="form-label"></label>
        <input asp-for="NombrePuesto" class="form-control" readonly />

    </div>


    <div class="mb-3">
        <label asp-for="Descripcion" class="form-label"></label>
        <input asp-for="Descripcion" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label asp-for="IdDepartamento" class="control-label"></label>
        <input asp-for="IdDepartamento" class="form-control" asp-items="ViewBag.IdDepartamento" readonly />
    </div>

    <button type="submit" class="btn btn-danger">Delete</button>

    <a asp-action="Index">Volver a la lista</a>
</form>

