@model PracticaMvcTi.PaginationDto<PracticaMvcTi.Models.Puesto>

@{
    ViewData["Title"] = "Index";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-secondary fw-bold">Gestion de Puestos</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg"></i> Nuevo Puesto
        </a>
    </div>


    <form asp-action="Index" method="get" class="mb-3">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Buscar por nombre..." value="@ViewBag.CurrentSearch">
            <button class="btn btn-outline-secondary" type="submit">
                <i class="bi bi-search"></i> Buscar
            </button>
            <a asp-action="Index" class="btn btn-outline-danger">Limpiar</a>
        </div>
    </form>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Descripcion</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Data)
                        {
                            <tr>

                                <td>
                                    <span class="fw-bold text-dark">@item.NombrePuesto </span>
                                </td>
                                <td>
                                    <span class="badge bg-info text-dark">@item.Descripcion</span>
                                </td>

                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.IdPuesto" class="btn btn-outline-warning btn-sm" title="Editar">
                                            Editar
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.IdPuesto" class="btn btn-outline-info btn-sm" title="Detalles">
                                            Detalles
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.IdPuesto" class="btn btn-outline-danger btn-sm" title="Eliminar">
                                            Borrar
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>


    <partial name="_Pagination" model="Model" />

</div>