@model PracticaMvcTi.ViewModels.DepartamentoViewModel.DepartamentoFormViewModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<form asp-action="Delete" method="post">

    <p>Seguro de quere borrar este Departamento?</p>
    <div class="mb-3">
        <label asp-for="NombreDepartamento" class="form-label"></label>
        <input asp-for="NombreDepartamento" class="form-control" readonly />

    </div>


    <div class="mb-3">
        <label asp-for="Descripcion" class="form-label"></label>
        <input asp-for="Descripcion" class="form-control" readonly />
    </div>

    <p style="margin-top:5px; margin:5px">Seguro de quere borrar este Departamento?</p>
    <div class="form-group">
        <input type="submit" value="Delete" class="btn btn-danger" />
    </div>

        <a asp-action="Index">Volver a la lista</a>
</form>

